{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "routes": [
    {
      "src": "^/assets/(.*)",
      "dest": "/dist/assets/$1"
    },
    {
       "src": "^/(logo.jpg|favicon.ico|vite.svg)",
       "dest": "/$1"
    },
    {
      "src": "^/api/(.*)",
      "dest": "api/server.js"
    },
    {
      "src": "^/(.*)",
      "dest": "api/server.js"
    }
  ],
  "functions": {
    "api/server.js": {
      "memory": 1024,
      "maxDuration": 25,
      "includeFiles": "dist/**"
    }
  }
}
