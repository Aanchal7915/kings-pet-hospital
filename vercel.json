{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "api/server.js"
    },
    {
      "source": "/assets/(.*)",
      "destination": "dist/assets/$1"
    },
    {
      "source": "/(.*)",
      "destination": "api/server.js"
    }
  ],
  "functions": {
    "api/server.js": {
      "memory": 1024,
      "maxDuration": 25,
      "includeFiles": "dist/**"
    }
  }
}
